# Supabase
# Preencher com as credenciais do projeto criado em supabase.com
# (Settings > API no painel do projeto)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública do site em produção (usada em metadata/SEO e em links
# absolutos). Em desenvolvimento pode ficar vazia — o app usa
# http://localhost:3000 como fallback automático.
# Exemplo em produção: https://app.vocalflow.com.br
NEXT_PUBLIC_SITE_URL=

# Resend (notificações por e-mail)
# Preencher com uma API Key criada em resend.com/api-keys
# Sem essa variável, o app funciona normalmente — os e-mails simplesmente
# não são enviados (aviso no log do servidor).
RESEND_API_KEY=

# Remetente dos e-mails. Sem preencher, usa o domínio de teste do Resend
# (onboarding@resend.dev), que só envia para o e-mail da própria conta
# Resend. Para produção, configure um domínio verificado, ex:
# "VocalFlow <notificacoes@vocalflow.com.br>"
RESEND_FROM_EMAIL=
